#!/usr/bin/env bash
# Start the full dev stack via process-compose:
#   - PostgreSQL on port 5434 (auto-init from dev/sql-seed/)
#   - DB migrations (auto-applied)
#   - Backend on port 8012 (ghcid hot-reload)
#   - Frontend on port 5173 (vite dev server)
#
# Press Ctrl+C to stop everything.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
cd "$PROJECT_DIR"

# Clean up any stale postgres lock from a previous crashed run
if [ -f .local/data/pg/postmaster.pid ]; then
  PID=$(head -1 .local/data/pg/postmaster.pid 2>/dev/null || echo "")
  if [ -n "$PID" ] && ! kill -0 "$PID" 2>/dev/null; then
    echo "[sc-dev] removing stale postmaster.pid"
    rm -f .local/data/pg/postmaster.pid
  fi
fi

exec nix run .#dev -- -t=false "$@"
