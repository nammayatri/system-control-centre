APP_STATE=SERVER
PORT=
NammaAP_ENV=p
NammaAP_KUBECTL_BIN=kubectl
NammaAP_DEFAULT_NAMESPACE=default
NammaAP_RUNNER_POLL_SECONDS=20
# false = one tracker per product+env per poll; true = allow multiple
NammaAP_IS_MULTI_RELEASE_PER_PRODUCT=False
NammaAP_MAX_K8S_RETRIES=3
NammaAP_STAGGER_COOLOFF_SECONDS=120
NammaAP_DELETE_OLD_DEPLOYMENT_ON_COMPLETE=True
NammaAP_OLD_DEPLOYMENT_CLEANUP_DELAY_SECONDS=0
NammaAP_AB_DECISION_ENABLED=False
NammaAP_ABORT_ON_AB_FAILURE=True
NammaAP_AB_COLLECT_METRICS_DELAY_SECONDS=30
NammaAP_AB_HOST=
NammaAP_AB_TRACKER_CREATE_PATH=/tracker/
NammaAP_AB_DECIDER_PATH_PREFIX=/decider/
NammaAP_AB_API_KEY=
NammaAP_AB_REQUEST_TIMEOUT_SECONDS=10
NammaAP_AB_HS_DECISION_ENABLED=False
NammaAP_AB_HS_HOST=
NammaAP_AB_HS_DECISION_PATH_PREFIX=
NammaAP_HPA_MAX_REPLICAS_BUFFER=
NammaAP_POSTGRES_HOST=
NammaAP_POSTGRES_PORT=
NammaAP_POSTGRES_USER=
NammaAP_POSTGRES_PASSWORD=
NammaAP_POSTGRES_DB=
# DB resolution order:
# 1) NammaAP_DATABASE_URL (recommended for cloud/AWS/GCP)
# 2) DATABASE_URL
# 3) NammaAP_POSTGRES_HOST/PORT/USER/PASSWORD/DB
NammaAP_DATABASE_URL=
DATABASE_URL=
NammaAP_MAINTENANCE_MODE=
NammaAP_APPROVER_EMAILS=
NammaAP_ALERT_WEBHOOK_CMD=
