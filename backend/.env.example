# ── Server ─────────────────────────────────────────────────────────
# All bootstrap env vars use the SC_* prefix (System Control).
# The legacy NammaAP_* prefix is accepted as a deprecated fallback — migrate
# deployments to SC_* and the fallback will be removed in a future release.
APP_STATE=SERVER
PORT=8012
SC_ENV=production

# ── Kubernetes ─────────────────────────────────────────────────────
SC_KUBECTL_BIN=kubectl
SC_MAX_K8S_RETRIES=3

# ── Database ───────────────────────────────────────────────────────
# DB resolution order:
# 1) SC_DATABASE_URL (recommended for cloud/AWS/GCP)
# 2) SC_POSTGRES_HOST/PORT/USER/PASSWORD/DB
SC_DATABASE_URL=
SC_POSTGRES_HOST=127.0.0.1
SC_POSTGRES_PORT=5432
SC_POSTGRES_USER=postgres
SC_POSTGRES_PASSWORD=postgres
SC_POSTGRES_DB=system_control

# ── Cluster sync (secrets) ────────────────────────────────────────
SYNC_CLUSTER_URL=
SYNC_CLUSTER_API_KEY=
SYNC_RELEASE_MANAGER=

# ── Slack (optional) ──────────────────────────────────────────────
SLACK_BOT_TOKEN=

# ── Runtime configs ───────────────────────────────────────────────
# All other settings (maintenance mode, runner poll, HPA, scale-down,
# approvals, multi-release, etc.) are managed via the server_config
# DB table and editable from the System Control dashboard.
