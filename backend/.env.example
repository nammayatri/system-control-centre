# ── Server ─────────────────────────────────────────────────────────
APP_STATE=SERVER
PORT=8012
NammaAP_ENV=production

# ── Kubernetes ─────────────────────────────────────────────────────
NammaAP_KUBECTL_BIN=kubectl
NammaAP_DEFAULT_NAMESPACE=default
NammaAP_MAX_K8S_RETRIES=3

# ── Database ───────────────────────────────────────────────────────
# DB resolution order:
# 1) NammaAP_DATABASE_URL (recommended for cloud/AWS/GCP)
# 2) NammaAP_POSTGRES_HOST/PORT/USER/PASSWORD/DB
NammaAP_DATABASE_URL=
NammaAP_POSTGRES_HOST=127.0.0.1
NammaAP_POSTGRES_PORT=5432
NammaAP_POSTGRES_USER=postgres
NammaAP_POSTGRES_PASSWORD=postgres
NammaAP_POSTGRES_DB=namma_ap

# ── Cluster sync (secrets) ────────────────────────────────────────
SYNC_CLUSTER_URL=
SYNC_CLUSTER_BASE_AUTH=

# ── Slack (optional) ──────────────────────────────────────────────
SLACK_BOT_TOKEN=

# ── Runtime configs ───────────────────────────────────────────────
# All other settings (maintenance mode, runner poll, HPA, scale-down,
# approvals, multi-release, etc.) are managed via the server_config
# DB table and editable from the System Control dashboard.
