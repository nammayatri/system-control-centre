# Local-dev secrets + settings for the Mobile Releases feature.
#
# Copy to `local-mobile-secrets.env` (same directory) and fill in. It is
# git-ignored. The dev shell (flake.nix backend process) SOURCES this file, so
# the SC_* secrets become environment variables read by Core.Secrets
# (loadGhCreds / loadPlayCreds / loadAscCreds) — secrets are NOT stored in the DB.
# The non-secret settings at the bottom are applied to the local DB by
# backend/scripts/setup-mobile-local.sh.
#
# Multi-line blobs (private keys, JSON) are base64-encoded to a single line:
#   macOS:  base64 -i path/to/file | tr -d '\n'
#   linux:  base64 -w0 path/to/file

# ═══ SECRETS (read from env — never the DB) ═══════════════════════════════════

# ── GitHub App ──
# Create a GitHub App (actions:write, contents:read, metadata:read), install it
# on the dispatch repo (install URL ends in the installation id), generate a key.
SC_GITHUB_APP_ID=
SC_GITHUB_APP_INSTALLATION_ID=
# base64 of the App's .pem private key:  base64 -i app.pem | tr -d '\n'
SC_GITHUB_APP_PRIVATE_KEY_B64=

# ── Play Console service account ──
# GCP → IAM → Service Accounts → Add Key → JSON. Invite the SA email in Play
# Console with at least "View app information".
# base64 of the JSON key:  base64 -i service-account.json | tr -d '\n'
SC_PLAY_SA_JSON_B64=

# ── App Store Connect (iOS — leave blank to skip) ──
SC_ASC_ISSUER_ID=
SC_ASC_KEY_ID=
# base64 of the .p8 key file:  base64 -i AuthKey_XXXX.p8 | tr -d '\n'
SC_ASC_PRIVATE_KEY_P8_B64=

# ═══ NON-SECRET local setup (applied to the DB by setup-mobile-local.sh) ══════

# Enable the dispatch endpoint (workflow_dispatch). "false" keeps mobile no-op.
MOBILE_DISPATCH_ENABLED=true

# Comma-separated app names to enable in app_catalog (from the seed: Cumta,
# NammaYatri, ManaYatri, Yatri, OdishaYatri, YatriSathi, KeralaSavaari, Bridge,
# BharatTaxi, Lynx). "all" enables every app; "none"/blank skips.
ENABLE_APPS=NammaYatri

# Optional: redirect ALL enabled apps' github_repo + workflow_path to a sandbox
# for safe end-to-end testing. Leave blank to keep the seeded production values.
SANDBOX_GITHUB_REPO=
SANDBOX_WORKFLOW_PATH=
