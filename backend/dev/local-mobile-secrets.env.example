# Local-dev secrets for the Mobile Releases feature.
#
# Copy this file to `local-mobile-secrets.env` (in this same directory) and fill
# in real values. `local-mobile-secrets.env` is git-ignored.
#
# After filling in, run:
#   nix develop --command bash backend/scripts/setup-mobile-local.sh
#
# That script will read this file and configure the local SCC server_config
# rows, enable the feature flag, and enable selected apps in app_catalog.

# ─────────────────────────────────────────────────────────────────────────────
# GitHub App credentials
# How to obtain: create a GitHub App with permissions
#   actions:write, contents:read, metadata:read
# Install it on the repo you'll dispatch against. The Installation URL ends in
# the installation ID. Generate a private key from the App settings page.
# ─────────────────────────────────────────────────────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=

# Absolute path to the App's downloaded private key (.pem file). The script
# reads the file contents and stores them in server_config.
GITHUB_APP_PRIVATE_KEY_PATH=

# ─────────────────────────────────────────────────────────────────────────────
# Play Console service-account credentials
# How to obtain: Google Cloud Console → IAM → Service Accounts → Create →
# Add Key → Create new JSON key. Then in Play Console → Users and permissions,
# invite the service account email and grant at least "View app information".
# ─────────────────────────────────────────────────────────────────────────────

# Absolute path to the downloaded JSON key file for the service account.
PLAY_SERVICE_ACCOUNT_JSON_PATH=

# ─────────────────────────────────────────────────────────────────────────────
# Feature flag — enable mobile dispatch endpoint
# Set to "true" to allow the dispatch endpoint to fire workflow_dispatch calls.
# Set to "false" to keep mobile completely no-op (SCC still serves UI but won't dispatch).
# ─────────────────────────────────────────────────────────────────────────────
MOBILE_DISPATCH_ENABLED=true

# ─────────────────────────────────────────────────────────────────────────────
# Apps to enable in the catalog
# Comma-separated app names (from the seed: Cumta, NammaYatri, ManaYatri, Yatri,
# OdishaYatri, YatriSathi, KeralaSavaari, Bridge, BharatTaxi, Lynx).
# Use "all" to enable every app. Use "none" or leave blank to skip.
# ─────────────────────────────────────────────────────────────────────────────
ENABLE_APPS=NammaYatri

# ─────────────────────────────────────────────────────────────────────────────
# Optional: sandbox override
# If set, the script will redirect ALL enabled apps' github_repo and
# workflow_path to the sandbox. Use this for safe end-to-end testing before
# pointing at the production repo (nammayatri/ny-react-native).
# Leave blank to keep the seeded production values.
# ─────────────────────────────────────────────────────────────────────────────
SANDBOX_GITHUB_REPO=
SANDBOX_WORKFLOW_PATH=

# ─────────────────────────────────────────────────────────────────────────────
# Database connection
# Defaults to the nix-dev URL. Override only if you're running against a
# different Postgres instance.
# ─────────────────────────────────────────────────────────────────────────────
# SC_DATABASE_URL=postgres://shailesh@127.0.0.1:5434/system_control
